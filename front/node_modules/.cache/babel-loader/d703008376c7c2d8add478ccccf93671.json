SAAA;AAAA,cAAA;AAAA,OAAA;AACA,aAAA,GAAA,CAAA,GAAA,CAAA,IAAA,MAAA;AACA,KAJA;;AAKA,IAAA,UAAA,CAAA,MAAA,EAAA;AACA,YAAA,GAAA,GAAA;AAAA,eAAA,QAAA;AAAA,eAAA,SAAA;AAAA,eAAA,SAAA;AAAA,eAAA;AAAA,OAAA;AACA,aAAA,GAAA,CAAA,MAAA,CAAA,IAAA,MAAA;AACA,KARA;;AASA,IAAA,MAAA,GAAA;AAAA,WAAA,SAAA,GAAA,CAAA;AAAA,WAAA,WAAA;AAAA,KATA;;AAUA,IAAA,WAAA,GAAA;AAAA,WAAA,UAAA,GAAA,EAAA;AAAA,WAAA,MAAA;AAAA,KAVA;;AAWA,IAAA,QAAA,GAAA;AACA,WAAA,KAAA,CAAA;AAAA,QAAA,GAAA,EAAA,qBAAA;AAAA,QAAA,MAAA,EAAA;AAAA,OAAA,EAAA,IAAA,CAAA,CAAA;AAAA,QAAA;AAAA,OAAA,KAAA;AACA,YAAA,IAAA,IAAA,IAAA,CAAA,IAAA,KAAA,CAAA,EAAA;AACA,gBAAA,IAAA,GAAA,IAAA,CAAA,IAAA,IAAA,EAAA;AACA,UAAA,IAAA,CAAA,OAAA,CAAA,IAAA,IAAA;AACA,gBAAA,IAAA,CAAA,IAAA,KAAA,KAAA,EAAA,KAAA,QAAA,GAAA,IAAA,CAAA,KAAA;AACA,gBAAA,IAAA,CAAA,IAAA,KAAA,IAAA,EAAA,KAAA,OAAA,GAAA,IAAA,CAAA,KAAA;AACA,WAHA;AAIA;AACA,OARA;AASA,WAAA,KAAA,CAAA;AAAA,QAAA,GAAA,EAAA,wBAAA;AAAA,QAAA,MAAA,EAAA;AAAA,OAAA,EAAA,IAAA,CAAA,CAAA;AAAA,QAAA;AAAA,OAAA,KAAA;AACA,YAAA,IAAA,IAAA,IAAA,CAAA,IAAA,KAAA,CAAA,EAAA;AACA,gBAAA,IAAA,GAAA,IAAA,CAAA,IAAA,IAAA,EAAA;AACA,gBAAA,IAAA,GAAA,IAAA,CAAA,IAAA,CAAA,CAAA,IAAA,CAAA,CAAA,IAAA,KAAA,KAAA,CAAA;AACA,cAAA,IAAA,EAAA,KAAA,UAAA,GAAA,IAAA,CAAA,KAAA;AACA;AACA,OANA;AAOA,KA5BA;;AA6BA,IAAA,WAAA,GAAA;AACA,WAAA,eAAA,GAAA,IAAA;AACA,UAAA,MAAA,GAAA;AAAA,QAAA,IAAA,EAAA,KAAA,SAAA;AAAA,QAAA,KAAA,EAAA,KAAA,QAAA;AAAA,QAAA,IAAA,EAAA;AAAA,OAAA;AACA,UAAA,KAAA,UAAA,CAAA,gBAAA,EAAA,MAAA,CAAA,kBAAA,CAAA,GAAA,MAAA,KAAA,UAAA,CAAA,gBAAA,GAAA,GAAA;AACA,UAAA,KAAA,UAAA,CAAA,gBAAA,EAAA,MAAA,CAAA,kBAAA,CAAA,GAAA,MAAA,KAAA,UAAA,CAAA,gBAAA,GAAA,GAAA;AACA,UAAA,KAAA,UAAA,CAAA,gBAAA,EAAA,MAAA,CAAA,kBAAA,CAAA,GAAA,MAAA,KAAA,UAAA,CAAA,gBAAA,GAAA,GAAA;AACA,UAAA,KAAA,UAAA,CAAA,gBAAA,EAAA,MAAA,CAAA,kBAAA,CAAA,GAAA,KAAA,UAAA,CAAA,gBAAA;AACA,UAAA,KAAA,UAAA,CAAA,UAAA,EAAA,MAAA,CAAA,YAAA,CAAA,GAAA,KAAA,UAAA,CAAA,UAAA;AACA,WAAA,KAAA,CAAA;AAAA,QAAA,GAAA,EAAA,eAAA;AAAA,QAAA,MAAA,EAAA,KAAA;AAAA,QAAA;AAAA,OAAA,EAAA,IAAA,CAAA,CAAA;AAAA,QAAA;AAAA,OAAA,KAAA;AACA,YAAA,IAAA,IAAA,IAAA,CAAA,IAAA,KAAA,CAAA,EAAA;AACA,eAAA,QAAA,GAAA,IAAA,CAAA,IAAA,CAAA,IAAA;AACA,eAAA,SAAA,GAAA,IAAA,CAAA,IAAA,CAAA,KAAA;AACA,SAHA,MAGA;AACA,eAAA,QAAA,GAAA,EAAA;AAAA,eAAA,SAAA,GAAA,CAAA;AACA;;AACA,aAAA,eAAA,GAAA,KAAA;AACA,OARA;AASA,KA9CA;;AA+CA,IAAA,gBAAA,CAAA,GAAA,EAAA;AAAA,WAAA,QAAA,GAAA,GAAA;AAAA,WAAA,SAAA,GAAA,CAAA;AAAA,WAAA,WAAA;AAAA,KA/CA;;AAgDA,IAAA,mBAAA,CAAA,GAAA,EAAA;AAAA,WAAA,SAAA,GAAA,GAAA;AAAA,WAAA,WAAA;AAAA,KAhDA;;AAiDA,IAAA,sBAAA,CAAA,GAAA,EAAA;AAAA,WAAA,kBAAA,GAAA,GAAA;AAAA,KAjDA;;AAkDA,IAAA,kBAAA,CAAA,EAAA,EAAA,IAAA,EAAA;AACA,WAAA,QAAA,GAAA,KAAA;AAAA,WAAA,eAAA,GAAA,IAAA;AACA,WAAA,SAAA,CAAA,MAAA;AAAA,aAAA,KAAA,CAAA,WAAA,CAAA,IAAA,CAAA,EAAA,EAAA,IAAA,IAAA,MAAA;AAAA,OAAA;AACA,KArDA;;AAsDA,IAAA,aAAA,CAAA,GAAA,EAAA;AACA,YAAA,MAAA,GAAA,GAAA,CAAA,IAAA,KAAA,GAAA,GAAA,GAAA,GAAA,GAAA;AACA,WAAA,KAAA,CAAA;AAAA,QAAA,GAAA,EAAA,oBAAA,GAAA,CAAA,EAAA,SAAA,MAAA,EAAA;AAAA,QAAA,MAAA,EAAA;AAAA,OAAA,EAAA,IAAA,CAAA,CAAA;AAAA,QAAA;AAAA,OAAA,KAAA;AACA,YAAA,IAAA,IAAA,IAAA,CAAA,IAAA,KAAA,CAAA,EAAA;AACA,eAAA,QAAA,CAAA,OAAA,CAAA,MAAA,KAAA,GAAA,GAAA,KAAA,GAAA,OAAA;AACA,eAAA,WAAA;AACA,SAHA,MAGA;AACA,eAAA,QAAA,CAAA,KAAA,CAAA,IAAA,CAAA,GAAA;AACA;AACA,OAPA;AAQA,KAhEA;;AAiEA,IAAA,YAAA,CAAA,GAAA,EAAA;AACA,WAAA,QAAA,CAAA,QAAA,GAAA,CAAA,gBAAA,WAAA,EAAA,IAAA,EAAA;AACA,QAAA,iBAAA,EAAA,IADA;AACA,QAAA,gBAAA,EAAA,IADA;AACA,QAAA,IAAA,EAAA;AADA,OAAA,EAEA,IAFA,CAEA,MAAA;AACA,aAAA,KAAA,CAAA;AAAA,UAAA,GAAA,EAAA,qBAAA,GAAA,CAAA,EAAA,EAAA;AAAA,UAAA,MAAA,EAAA;AAAA,SAAA,EAAA,IAAA,CAAA,CAAA;AAAA,UAAA;AAAA,SAAA,KAAA;AACA,cAAA,IAAA,IAAA,IAAA,CAAA,IAAA,KAAA,CAAA,EAAA;AACA,iBAAA,QAAA,CAAA,OAAA,CAAA,kBAAA;AACA,WAFA,MAEA;AACA,iBAAA,QAAA,CAAA,KAAA,CAAA,IAAA,CAAA,GAAA,IAAA,MAAA;AACA;AACA,SANA;AAOA,OAVA;AAWA,KA7EA;;AA8EA,IAAA,aAAA,CAAA,EAAA,EAAA;AACA,YAAA,GAAA,GAAA,EAAA,GAAA,CAAA,MAAA,CAAA,EAAA,CAAA,CAAA,GAAA,KAAA,kBAAA,CAAA,GAAA,CAAA,IAAA,IAAA,MAAA,CAAA,IAAA,CAAA,EAAA,CAAA,CAAA;AACA,WAAA,QAAA,CAAA,QAAA,EAAA,GAAA,IAAA,GAAA,MAAA,MAAA,EAAA,IAAA,EAAA;AACA,QAAA,iBAAA,EAAA,IADA;AACA,QAAA,gBAAA,EAAA,IADA;AACA,QAAA,IAAA,EAAA;AADA,OAAA,EAEA,IAFA,CAEA,MAAA;AACA,aAAA,KAAA,CAAA;AAAA,UAAA,GAAA,EAAA,iBAAA;AAAA,UAAA,MAAA,EAAA,MAAA;AAAA,UAAA,IAAA,EAAA;AAAA,SAAA,EAAA,IAAA,CAAA,CAAA;AAAA,UAAA;AAAA,SAAA,KAAA;AACA,cAAA,IAAA,IAAA,IAAA,CAAA,IAAA,KAAA,CAAA,EAAA;AACA,iBAAA,QAAA,CAAA;AAAA,cAAA,OAAA,EAAA,MAAA;AAAA,cAAA,IAAA,EAAA,SAAA;AAAA,cAAA,QAAA,EAAA,IAAA;AAAA,cAAA,OAAA,EAAA,MAAA,KAAA,MAAA;AAAA,aAAA;AACA,WAFA,MAEA;AACA,iBAAA,QAAA,CAAA,KAAA,CAAA,IAAA,CAAA,GAAA;AACA;AACA,SANA;AAOA,OAVA;AAWA;;AA3FA;AAtBA,CAAA","sourcesContent":["<template>\n  <div class=\"main-content\">\n    <div v-if=\"showFlag\">\n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"form-content\">\n        <el-row :gutter=\"20\" class=\"slt\">\n          <el-form-item label=\"竞赛名称\">\n            <el-input v-model=\"searchForm.jingsaimingcheng\" placeholder=\"竞赛名称\" clearable prefix-icon=\"el-icon-search\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"获奖学生\">\n            <el-input v-model=\"searchForm.xueshengxingming\" placeholder=\"学生姓名\" clearable prefix-icon=\"el-icon-user\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"学院\">\n            <el-input v-model=\"searchForm.xueyuanmingcheng\" placeholder=\"学院名称\" clearable></el-input>\n          </el-form-item>\n          <el-form-item label=\"奖项等级\">\n            <el-select v-model=\"searchForm.jiangxiangdengji\" placeholder=\"全部\" clearable style=\"width:130px\">\n              <el-option label=\"一等奖\" value=\"一等奖\"></el-option>\n              <el-option label=\"二等奖\" value=\"二等奖\"></el-option>\n              <el-option label=\"三等奖\" value=\"三等奖\"></el-option>\n              <el-option label=\"优秀奖\" value=\"优秀奖\"></el-option>\n            </el-select>\n          </el-form-item>\n          <el-form-item label=\"竞赛级别\">\n            <el-select v-model=\"searchForm.jingsaijib\" placeholder=\"全部\" clearable style=\"width:130px\">\n              <el-option label=\"校级\" value=\"校级\"></el-option>\n              <el-option label=\"省级\" value=\"省级\"></el-option>\n              <el-option label=\"国家级\" value=\"国家级\"></el-option>\n              <el-option label=\"国际级\" value=\"国际级\"></el-option>\n            </el-select>\n          </el-form-item>\n          <el-form-item>\n            <el-button type=\"primary\" icon=\"el-icon-search\" @click=\"search()\">查询</el-button>\n            <el-button icon=\"el-icon-refresh\" @click=\"resetSearch()\">重置</el-button>\n          </el-form-item>\n        </el-row>\n        <el-row class=\"ad\">\n          <el-form-item>\n            <el-button v-if=\"isAuth('huojiang','新增')\" type=\"success\" icon=\"el-icon-plus\" @click=\"addOrUpdateHandler()\">新增获奖</el-button>\n            <el-button v-if=\"isAuth('huojiang','删除')\" type=\"danger\" icon=\"el-icon-delete\" :disabled=\"dataListSelections.length <= 0\" @click=\"deleteHandler()\">批量删除</el-button>\n            <el-button type=\"warning\" icon=\"el-icon-data-analysis\" @click=\"$router.push('/tongji')\">获奖统计</el-button>\n          </el-form-item>\n        </el-row>\n      </el-form>\n\n      <!-- 统计卡片 -->\n      <el-row :gutter=\"16\" style=\"margin-bottom:16px\">\n        <el-col :span=\"6\">\n          <div class=\"stat-card\" style=\"background:linear-gradient(135deg,#667eea,#764ba2)\">\n            <div class=\"stat-num\">{{ totalPage }}</div>\n            <div class=\"stat-label\">获奖总数</div>\n          </div>\n        </el-col>\n        <el-col :span=\"6\">\n          <div class=\"stat-card\" style=\"background:linear-gradient(135deg,#f093fb,#f5576c)\">\n            <div class=\"stat-num\">{{ guojiaji }}</div>\n            <div class=\"stat-label\">国家级获奖</div>\n          </div>\n        </el-col>\n        <el-col :span=\"6\">\n          <div class=\"stat-card\" style=\"background:linear-gradient(135deg,#4facfe,#00f2fe)\">\n            <div class=\"stat-num\">{{ shengji }}</div>\n            <div class=\"stat-label\">省级获奖</div>\n          </div>\n        </el-col>\n        <el-col :span=\"6\">\n          <div class=\"stat-card\" style=\"background:linear-gradient(135deg,#43e97b,#38f9d7)\">\n            <div class=\"stat-num\">{{ yidengjang }}</div>\n            <div class=\"stat-label\">一等奖数量</div>\n          </div>\n        </el-col>\n      </el-row>\n\n      <div class=\"table-content\">\n        <el-table\n          :data=\"dataList\"\n          border\n          stripe\n          v-loading=\"dataListLoading\"\n          @selection-change=\"selectionChangeHandler\"\n          style=\"width:100%\">\n          <el-table-column type=\"selection\" width=\"50\" align=\"center\"></el-table-column>\n          <el-table-column type=\"index\" label=\"序号\" width=\"60\" align=\"center\"></el-table-column>\n          <el-table-column prop=\"jingsaimingcheng\" label=\"竞赛名称\" min-width=\"160\" show-overflow-tooltip></el-table-column>\n          <el-table-column prop=\"jingsaijib\" label=\"级别\" width=\"90\" align=\"center\">\n            <template slot-scope=\"scope\">\n              <el-tag :type=\"jibType(scope.row.jingsaijib)\" size=\"mini\">{{ scope.row.jingsaijib }}</el-tag>\n            </template>\n          </el-table-column>\n          <el-table-column prop=\"xueshengxingming\" label=\"获奖学生\" width=\"100\" align=\"center\"></el-table-column>\n          <el-table-column prop=\"xueyuanmingcheng\" label=\"学院\" min-width=\"120\" show-overflow-tooltip></el-table-column>\n          <el-table-column prop=\"tuanduimingcheng\" label=\"团队名称\" min-width=\"100\" show-overflow-tooltip></el-table-column>\n          <el-table-column prop=\"jiangxiangmingcheng\" label=\"奖项名称\" min-width=\"120\" show-overflow-tooltip></el-table-column>\n          <el-table-column prop=\"jiangxiangdengji\" label=\"获奖等级\" width=\"100\" align=\"center\">\n            <template slot-scope=\"scope\">\n              <el-tag :type=\"dengjiType(scope.row.jiangxiangdengji)\" size=\"mini\">{{ scope.row.jiangxiangdengji }}</el-tag>\n            </template>\n          </el-table-column>\n          <el-table-column prop=\"jiaoshixingming\" label=\"指导教师\" width=\"100\" align=\"center\"></el-table-column>\n          <el-table-column prop=\"huojiangriqi\" label=\"获奖日期\" width=\"110\" align=\"center\"></el-table-column>\n          <el-table-column prop=\"sfgs\" label=\"公示状态\" width=\"90\" align=\"center\">\n            <template slot-scope=\"scope\">\n              <el-tag :type=\"scope.row.sfgs === '是' ? 'success' : 'info'\" size=\"mini\">\n                {{ scope.row.sfgs === '是' ? '已公示' : '未公示' }}\n              </el-tag>\n            </template>\n          </el-table-column>\n          <el-table-column label=\"操作\" width=\"260\" align=\"center\" fixed=\"right\">\n            <template slot-scope=\"scope\">\n              <el-button type=\"success\" size=\"mini\" icon=\"el-icon-view\" @click=\"addOrUpdateHandler(scope.row.id,'info')\">详情</el-button>\n              <el-button v-if=\"isAuth('huojiang','修改')\" type=\"primary\" size=\"mini\" icon=\"el-icon-edit\" @click=\"addOrUpdateHandler(scope.row.id)\">修改</el-button>\n              <el-button type=\"warning\" size=\"mini\" icon=\"el-icon-medal\" @click=\"generateCert(scope.row)\">生成证书</el-button>\n              <el-button v-if=\"isAuth('huojiang','公示')\" type=\"info\" size=\"mini\" @click=\"toggleGongshi(scope.row)\">\n                {{ scope.row.sfgs === '是' ? '取消公示' : '公示' }}\n              </el-button>\n              <el-button v-if=\"isAuth('huojiang','删除')\" type=\"danger\" size=\"mini\" icon=\"el-icon-delete\" @click=\"deleteHandler(scope.row.id)\">删除</el-button>\n            </template>\n          </el-table-column>\n        </el-table>\n        <el-pagination\n          @size-change=\"sizeChangeHandle\"\n          @current-change=\"currentChangeHandle\"\n          :current-page=\"pageIndex\"\n          :page-sizes=\"[10, 20, 50, 100]\"\n          :page-size=\"pageSize\"\n          :total=\"totalPage\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          style=\"margin-top:16px;text-align:right\">\n        </el-pagination>\n      </div>\n    </div>\n    <add-or-update v-if=\"addOrUpdateFlag\" :parent=\"this\" ref=\"addOrUpdate\"></add-or-update>\n  </div>\n</template>\n\n<script>\nimport AddOrUpdate from './add-or-update'\nexport default {\n  data() {\n    return {\n      searchForm: {},\n      dataList: [],\n      pageIndex: 1,\n      pageSize: 10,\n      totalPage: 0,\n      guojiaji: 0,\n      shengji: 0,\n      yidengjang: 0,\n      dataListLoading: false,\n      dataListSelections: [],\n      showFlag: true,\n      addOrUpdateFlag: false\n    }\n  },\n  components: { AddOrUpdate },\n  created() {\n    this.getDataList()\n    this.getStats()\n  },\n  methods: {\n    jibType(jib) {\n      const map = { '国际级': 'danger', '国家级': 'warning', '省级': 'primary', '校级': 'info' }\n      return map[jib] || 'info'\n    },\n    dengjiType(dengji) {\n      const map = { '一等奖': 'danger', '二等奖': 'warning', '三等奖': 'primary', '优秀奖': 'info' }\n      return map[dengji] || 'info'\n    },\n    search() { this.pageIndex = 1; this.getDataList() },\n    resetSearch() { this.searchForm = {}; this.search() },\n    getStats() {\n      this.$http({ url: 'huojiang/tongji/jib', method: 'get' }).then(({ data }) => {\n        if (data && data.code === 0) {\n          const list = data.data || []\n          list.forEach(item => {\n            if (item.name === '国家级') this.guojiaji = item.value\n            if (item.name === '省级') this.shengji = item.value\n          })\n        }\n      })\n      this.$http({ url: 'huojiang/tongji/dengji', method: 'get' }).then(({ data }) => {\n        if (data && data.code === 0) {\n          const list = data.data || []\n          const item = list.find(i => i.name === '一等奖')\n          if (item) this.yidengjang = item.value\n        }\n      })\n    },\n    getDataList() {\n      this.dataListLoading = true\n      let params = { page: this.pageIndex, limit: this.pageSize, sort: 'id' }\n      if (this.searchForm.jingsaimingcheng) params['jingsaimingcheng'] = '%' + this.searchForm.jingsaimingcheng + '%'\n      if (this.searchForm.xueshengxingming) params['xueshengxingming'] = '%' + this.searchForm.xueshengxingming + '%'\n      if (this.searchForm.xueyuanmingcheng) params['xueyuanmingcheng'] = '%' + this.searchForm.xueyuanmingcheng + '%'\n      if (this.searchForm.jiangxiangdengji) params['jiangxiangdengji'] = this.searchForm.jiangxiangdengji\n      if (this.searchForm.jingsaijib) params['jingsaijib'] = this.searchForm.jingsaijib\n      this.$http({ url: 'huojiang/page', method: 'get', params }).then(({ data }) => {\n        if (data && data.code === 0) {\n          this.dataList = data.data.list\n          this.totalPage = data.data.total\n        } else {\n          this.dataList = []; this.totalPage = 0\n        }\n        this.dataListLoading = false\n      })\n    },\n    sizeChangeHandle(val) { this.pageSize = val; this.pageIndex = 1; this.getDataList() },\n    currentChangeHandle(val) { this.pageIndex = val; this.getDataList() },\n    selectionChangeHandler(val) { this.dataListSelections = val },\n    addOrUpdateHandler(id, type) {\n      this.showFlag = false; this.addOrUpdateFlag = true\n      this.$nextTick(() => { this.$refs.addOrUpdate.init(id, type || 'else') })\n    },\n    toggleGongshi(row) {\n      const newVal = row.sfgs === '是' ? '否' : '是'\n      this.$http({ url: `huojiang/gongshi/${row.id}?sfgs=${newVal}`, method: 'get' }).then(({ data }) => {\n        if (data && data.code === 0) {\n          this.$message.success(newVal === '是' ? '已公示' : '已取消公示')\n          this.getDataList()\n        } else {\n          this.$message.error(data.msg)\n        }\n      })\n    },\n    generateCert(row) {\n      this.$confirm(`确认为 [${row.xueshengxingming}] 生成电子证书？`, '提示', {\n        confirmButtonText: '确定', cancelButtonText: '取消', type: 'info'\n      }).then(() => {\n        this.$http({ url: `zhengshu/generate/${row.id}`, method: 'get' }).then(({ data }) => {\n          if (data && data.code === 0) {\n            this.$message.success('证书生成成功，请前往证书管理查看')\n          } else {\n            this.$message.error(data.msg || '生成失败')\n          }\n        })\n      })\n    },\n    deleteHandler(id) {\n      const ids = id ? [Number(id)] : this.dataListSelections.map(item => Number(item.id))\n      this.$confirm(`确定进行[${id ? '删除' : '批量删除'}]操作？`, '提示', {\n        confirmButtonText: '确定', cancelButtonText: '取消', type: 'warning'\n      }).then(() => {\n        this.$http({ url: 'huojiang/delete', method: 'post', data: ids }).then(({ data }) => {\n          if (data && data.code === 0) {\n            this.$message({ message: '操作成功', type: 'success', duration: 1500, onClose: () => this.search() })\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.stat-card {\n  border-radius: 12px;\n  padding: 20px 24px;\n  color: #fff;\n  text-align: center;\n  box-shadow: 0 4px 15px rgba(0,0,0,0.1);\n}\n.stat-num { font-size: 32px; font-weight: bold; }\n.stat-label { font-size: 14px; margin-top: 4px; opacity: 0.9; }\n.slt { margin: 0 !important; display: flex; flex-wrap: wrap; }\n.ad { margin: 8px 0 !important; display: flex; }\n</style>\n"],"sourceRoot":"src/views/modules/huojiang"}]}