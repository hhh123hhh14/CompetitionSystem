          font-size: 11px;\n          color: rgba(255,255,255,0.55);\n          font-weight: 400;\n        }\n\n        .user-name {\n          font-size: 14px;\n          color: #fff;\n          font-weight: 600;\n        }\n      }\n    }\n\n    .divider {\n      width: 1px;\n      height: 28px;\n      background: rgba(255,255,255,0.15);\n    }\n\n    .logout-btn {\n      display: flex;\n      align-items: center;\n      gap: 6px;\n      padding: 8px 14px;\n      border-radius: 8px;\n      color: rgba(255,255,255,0.7);\n      cursor: pointer;\n      transition: all 0.2s;\n      font-size: 14px;\n\n      i {\n        font-size: 16px;\n      }\n\n      &:hover {\n        background: rgba(255,255,255,0.1);\n        color: #fff;\n      }\n    }\n  }\n}\n</style>\n"]}]}