     component: jingsaibaoming\n    },\n    {\n      path: '/jiaoshi',\n      name: '教师管理',\n      component: jiaoshi\n    },\n    {\n      path: '/xuesheng',\n      name: '学生管理',\n      component: xuesheng\n    },\n    {\n      path: '/banjileixing',\n      name: '班级类型',\n      component: banjileixing\n    },\n    // ===== 赛中：作品提交 + 评审管理 =====\n    {\n      path: '/zuopintijiao',\n      name: '作品提交',\n      component: zuopintijiao\n    },\n    {\n      path: '/zuopindafen',\n      name: '作品评审',\n      component: zuopindafen\n    },\n    // ===== 赛后：成绩 + 证书 + 统计 =====\n    {\n      path: '/huojiang',\n      name: '获奖管理',\n      component: huojiang\n    },\n    {\n      path: '/zhengshu',\n      name: '证书管理',\n      component: zhengshu\n    },\n    {\n      path: '/tongji',\n      name: '统计分析',\n      component: tongji\n    }\n    ]\n  },\n  {\n    path: '/login',\n    name: 'login',\n    component: Login,\n    meta: {icon:'', title:'login'}\n  },\n  {\n    path: '/register',\n    name: 'register',\n    component: register,\n    meta: {icon:'', title:'register'}\n  },\n  {\n    path: '/',\n    name: '首页',\n    redirect: '/index'\n  },\n  {\n    path: '*',\n    component: NotFound\n  }\n]\n\nconst router = new VueRouter({\n  mode: 'hash',\n  routes\n})\n\nexport default router;\n"]}]}