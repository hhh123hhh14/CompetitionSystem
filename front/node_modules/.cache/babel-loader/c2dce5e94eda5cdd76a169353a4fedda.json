{"remainingRequest":"C:\\Users\\NICE\\CollegeStudentCompetitionSystem\\front\\node_modules\\babel-loader\\lib\\index.js!C:\\Users\\NICE\\CollegeStudentCompetitionSystem\\front\\node_modules\\cache-loader\\dist\\cjs.js??ref--0-0!C:\\Users\\NICE\\CollegeStudentCompetitionSystem\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\NICE\\CollegeStudentCompetitionSystem\\front\\src\\components\\common\\BreadCrumbs.vue?vue&type=script&lang=js&","dependencies":[{"path":"C:\\Users\\NICE\\CollegeStudentCompetitionSystem\\front\\src\\components\\common\\BreadCrumbs.vue","mtime":1773415110799},{"path":"C:\\Users\\NICE\\CollegeStudentCompetitionSystem\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"C:\\Users\\NICE\\CollegeStudentCompetitionSystem\\front\\node_modules\\babel-loader\\lib\\index.js","mtime":499162500000},{"path":"C:\\Users\\NICE\\CollegeStudentCompetitionSystem\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"C:\\Users\\NICE\\CollegeStudentCompetitionSystem\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["BreadCrumbs.vue"],"names":[],"mappings":";;;;;;;;;;;AAYA,OAAA,YAAA,MAAA,gBAAA;AACA,SAAA,aAAA,QAAA,cAAA;AACA,eAAA;AACA,EAAA,IAAA,GAAA;AACA,WAAA;AACA,MAAA,SAAA,EAAA;AADA,KAAA;AAGA,GALA;;AAMA,EAAA,KAAA,EAAA;AACA,IAAA,MAAA,GAAA;AACA,WAAA,aAAA;AACA;;AAHA,GANA;;AAWA,EAAA,OAAA,GAAA;AACA,SAAA,aAAA;AACA,SAAA,qBAAA;AACA,GAdA;;AAeA,EAAA,OAAA,EAAA;AACA,IAAA,aADA;;AAEA,IAAA,aAAA,GAAA;AACA;AACA,UAAA,KAAA,GAAA,KAAA,MAAA;AACA,UAAA,OAAA,GAAA,KAAA,CAAA,OAAA,CAAA,MAAA,CAAA,IAAA,IAAA,IAAA,CAAA,IAAA,CAAA;AACA,YAAA,KAAA,GAAA,OAAA,CAAA,CAAA,CAAA;AACA,MAAA,OAAA,GAAA,CAAA;AAAA,QAAA,IAAA,EAAA;AAAA,OAAA,EAAA,MAAA,CAAA,OAAA,CAAA;AAEA,WAAA,SAAA,GAAA,OAAA,CAAA,MAAA,CAAA,IAAA,IAAA,IAAA,CAAA,IAAA,CAAA;AACA,KAVA;;AAWA,IAAA,WAAA,CAAA,KAAA,EAAA;AACA,YAAA,IAAA,GAAA,KAAA,IAAA,KAAA,CAAA,IAAA;;AACA,UAAA,CAAA,IAAA,EAAA;AACA,eAAA,KAAA;AACA;;AACA,aAAA,IAAA,CAAA,IAAA,GAAA,iBAAA,OAAA,QAAA,iBAAA,EAAA;AACA,KAjBA;;AAkBA,IAAA,WAAA,CAAA,IAAA,EAAA;AACA;AACA,YAAA;AAAA,QAAA;AAAA,UAAA,KAAA,MAAA;AACA,UAAA,MAAA,GAAA,YAAA,CAAA,OAAA,CAAA,IAAA,CAAA;AACA,aAAA,MAAA,CAAA,MAAA,CAAA;AACA,KAvBA;;AAwBA,IAAA,UAAA,CAAA,IAAA,EAAA;AACA,YAAA;AAAA,QAAA,QAAA;AAAA,QAAA;AAAA,UAAA,IAAA;;AACA,UAAA,QAAA,EAAA;AACA,aAAA,OAAA,CAAA,IAAA,CAAA,QAAA;AACA;AACA;;AACA,WAAA,OAAA,CAAA,IAAA,CAAA,IAAA;AACA,KA/BA;;AAgCA,IAAA,qBAAA,CAAA,GAAA,EAAA;AACA,WAAA,SAAA,CAAA,MAAA;AACA,QAAA,QAAA,CAAA,gBAAA,CAAA,2CAAA,EAAA,OAAA,CAAA,EAAA,IAAA;AACA,UAAA,EAAA,CAAA,SAAA,GAAA,IAAA;AACA,UAAA,EAAA,CAAA,KAAA,CAAA,KAAA,GAAA,qBAAA;AACA,SAHA;AAIA,QAAA,QAAA,CAAA,gBAAA,CAAA,yCAAA,EAAA,OAAA,CAAA,EAAA,IAAA;AACA,UAAA,EAAA,CAAA,KAAA,CAAA,KAAA,GAAA,SAAA;AACA,SAFA;AAGA,QAAA,QAAA,CAAA,gBAAA,CAAA,oDAAA,EAAA,OAAA,CAAA,EAAA,IAAA;AACA,UAAA,EAAA,CAAA,KAAA,CAAA,KAAA,GAAA,wBAAA;AACA,SAFA;AAIA,YAAA,GAAA,GAAA,UAAA;;AACA,YAAA,eAAA,GAAA,EAAA;AACA,cAAA,UAAA,GAAA,MAAA;AACA,UAAA,UAAA,GAAA,QAAA,CAAA,UAAA,CAAA,GAAA,EAAA,GAAA,IAAA;AACA,UAAA,QAAA,CAAA,gBAAA,CAAA,iBAAA,EAAA,OAAA,CAAA,EAAA,IAAA;AACA,YAAA,EAAA,CAAA,KAAA,CAAA,SAAA,GAAA,UAAA;AACA,WAFA;AAGA;AAEA,OArBA;AAsBA;;AAvDA;AAfA,CAAA","sourcesContent":["<template>\r\n  <el-breadcrumb class=\"app-breadcrumb\" separator=\"⭐⭐\" style=\"height:50px;backgroundColor:rgba(197, 159, 34, 1);borderRadius:16px;padding:0px 20px 0px 20px;boxShadow:;borderWidth:2px;borderStyle:dotted solid double dashed;borderColor:rgba(237, 214, 84, 0.03);\">\r\n    <transition-group name=\"breadcrumb\" class=\"box\" :style=\"2==1?'justifyContent:flex-start;':2==2?'justifyContent:center;':'justifyContent:flex-end;'\">\r\n      <el-breadcrumb-item v-for=\"(item,index) in levelList\" :key=\"item.path\">\r\n        <span v-if=\"item.redirect==='noRedirect'||index==levelList.length-1\" class=\"no-redirect\">{{ item.name }}</span>\r\n        <a v-else @click.prevent=\"handleLink(item)\">{{ item.name }}</a>\r\n      </el-breadcrumb-item>\r\n    </transition-group>\r\n  </el-breadcrumb>\r\n</template>\r\n\r\n<script>\r\nimport pathToRegexp from 'path-to-regexp'\r\nimport { generateTitle } from '@/utils/i18n'\r\nexport default {\r\n  data() {\r\n    return {\r\n      levelList: null\r\n    }\r\n  },\r\n  watch: {\r\n    $route() {\r\n      this.getBreadcrumb()\r\n    }\r\n  },\r\n  created() {\r\n    this.getBreadcrumb()\r\n    this.breadcrumbStyleChange()\r\n  },\r\n  methods: {\r\n    generateTitle,\r\n    getBreadcrumb() {\r\n      // only show routes with meta.title\r\n      let route = this.$route\r\n      let matched = route.matched.filter(item => item.meta)\r\n      const first = matched[0]\r\n      matched = [{ path: '/index' }].concat(matched)\r\n\r\n      this.levelList = matched.filter(item => item.meta)\r\n    },\r\n    isDashboard(route) {\r\n      const name = route && route.name\r\n      if (!name) {\r\n        return false\r\n      }\r\n      return name.trim().toLocaleLowerCase() === 'Index'.toLocaleLowerCase()\r\n    },\r\n    pathCompile(path) {\r\n      // To solve this problem https://github.com/PanJiaChen/vue-element-admin/issues/561\r\n      const { params } = this.$route\r\n      var toPath = pathToRegexp.compile(path)\r\n      return toPath(params)\r\n    },\r\n    handleLink(item) {\r\n      const { redirect, path } = item\r\n      if (redirect) {\r\n        this.$router.push(redirect)\r\n        return\r\n      }\r\n      this.$router.push(path)\r\n    },\r\n    breadcrumbStyleChange(val) {\r\n      this.$nextTick(()=>{\r\n        document.querySelectorAll('.app-breadcrumb .el-breadcrumb__separator').forEach(el=>{\r\n          el.innerText = \"⭐⭐\"\r\n          el.style.color = \"rgba(15, 15, 16, 1)\"\r\n        })\r\n        document.querySelectorAll('.app-breadcrumb .el-breadcrumb__inner a').forEach(el=>{\r\n          el.style.color = \"#303133\"\r\n        })\r\n        document.querySelectorAll('.app-breadcrumb .el-breadcrumb__inner .no-redirect').forEach(el=>{\r\n          el.style.color = \"rgba(255, 255, 255, 1)\"\r\n        })\r\n\r\n        let str = \"vertical\"\r\n        if(\"vertical\" === str) {\r\n          let headHeight = \"60px\"\r\n          headHeight = parseInt(headHeight) + 10 + 'px'\r\n          document.querySelectorAll('.app-breadcrumb').forEach(el=>{\r\n            el.style.marginTop = headHeight\r\n          })\r\n        }\r\n\r\n      })\r\n    },\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.app-breadcrumb {\r\n  display: block;\r\n  font-size: 14px;\r\n  line-height: 50px;\r\n\r\n  .box {\r\n    display: flex;\r\n    width: 100%;\r\n    height: 100%;\r\n    justify-content: flex-start;\r\n    align-items: center;\r\n  }\r\n\r\n  .no-redirect {\r\n    color: #97a8be;\r\n    cursor: text;\r\n  }\r\n}\r\n</style>\r\n"],"sourceRoot":"src/components/common"}]}