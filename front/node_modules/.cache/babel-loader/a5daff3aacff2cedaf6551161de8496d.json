,EAAA;QAAA,CAAA;MACA,CAAA;MACA,YAAA,EAAA,CAAA,IAAA,EAAA,IAAA,CAAA;MACA,QAAA,EAAA,EAAA;MACA,YAAA,EAAA,EAAA;MAAA;MACA,WAAA,EAAA;QACA,IAAA,EAAA,IAAA;QAAA,MAAA,EAAA,IAAA;QAAA,QAAA,EAAA,MAAA;QACA,KAAA,EAAA,IAAA;QAAA,QAAA,EAAA,IAAA;QAAA,MAAA,EAAA,IAAA;QAAA,IAAA,EAAA;MACA;IACA,CAAA;EACA,CAAA;EACA,QAAA,EAAA;IACA,SAAA,CAAA,EAAA;MAAA,OAAA,8BAAA;IAAA,CAAA;IACA,aAAA,CAAA,EAAA;MAAA,OAAA;QAAA,KAAA,EAAA,IAAA,CAAA,QAAA,CAAA,GAAA,CAAA,OAAA;MAAA,CAAA;IAAA;EACA,CAAA;EACA,OAAA,EAAA;IACA,IAAA,CAAA,EAAA,EAAA,IAAA,EAAA;MACA,IAAA,CAAA,IAAA,GAAA,IAAA,IAAA,MAAA;MACA,IAAA,CAAA,QAAA,GAAA;QAAA,SAAA,EAAA,KAAA;QAAA,KAAA,EAAA,IAAA;QAAA,UAAA,EAAA;MAAA,CAAA;MACA,IAAA,CAAA,QAAA,GAAA,EAAA;MACA,IAAA,CAAA,YAAA,GAAA,EAAA;MACA,IAAA,EAAA,EAAA;QACA,IAAA,CAAA,KAAA,CAAA;UAAA,GAAA,EAAA,qBAAA,EAAA,EAAA;UAAA,MAAA,EAAA;QAAA,CAAA,CAAA,CAAA,IAAA,CAAA,CAAA;UAAA;QAAA,CAAA,KAAA;UACA,IAAA,IAAA,IAAA,IAAA,CAAA,IAAA,KAAA,CAAA,EAAA;YACA,IAAA,CAAA,QAAA,GAAA,IAAA,CAAA,IAAA;YACA,IAAA,IAAA,CAAA,QAAA,CAAA,cAAA,EAAA;cACA,IAAA,CAAA,QAAA,GAAA,CAAA;gBAAA,IAAA,EAAA,IAAA;gBAAA,GAAA,EAAA,IAAA,CAAA,QAAA,CAAA;cAAA,CAAA,CAAA;YACA;YACA;YACA,IAAA,CAAA,gBAAA,CAAA,EAAA,CAAA;UACA;QACA,CAAA,CAAA;MACA;IACA,CAAA;IACA,gBAAA,CAAA,cAAA,EAAA;MACA,IAAA,CAAA,KAAA,CAAA;QAAA,GAAA,EAAA,qBAAA,cAAA,EAAA;QAAA,MAAA,EAAA;MAAA,CAAA,CAAA,CAAA,IAAA,CAAA,CAAA;QAAA;MAAA,CAAA,KAAA;QACA,IAAA,IAAA,IAAA,IAAA,CAAA,IAAA,KAAA,CAAA,EAAA;UACA,IAAA,CAAA,YAAA,GAAA,IAAA,CAAA,IAAA,IAAA,EAAA;QACA;MACA,CAAA,CAAA;IACA,CAAA;IACA,mBAAA,CAAA,GAAA,EAAA;MACA,IAAA,GAAA,CAAA,IAAA,KAAA,CAAA,EAAA,IAAA,CAAA,QAAA,CAAA,cAAA,GAAA,GAAA,CAAA,IAAA;IACA,CAAA;IACA,YAAA,CAAA,EAAA;MAAA,IAAA,CAAA,QAAA,CAAA,cAAA,GAAA,EAAA;IAAA,CAAA;IACA,UAAA,CAAA,QAAA,EAAA;MACA,IAAA,CAAA,KAAA,CAAA,QAAA,CAAA,CAAA,QAAA,CAAA,KAAA,IAAA;QACA,IAAA,CAAA,KAAA,EAAA;QACA,MAAA,GAAA,GAAA,IAAA,CAAA,QAAA,CAAA,EAAA,GAAA,qBAAA,GAAA,mBAAA;QACA,IAAA,CAAA,KAAA,CAAA;UAAA,GAAA;UAAA,MAAA,EAAA,MAAA;UAAA,IAAA,EAAA,IAAA,CAAA;QAAA,CAAA,CAAA,CAAA,IAAA,CAAA,CAAA;UAAA;QAAA,CAAA,KAAA;UACA,IAAA,IAAA,IAAA,IAAA,CAAA,IAAA,KAAA,CAAA,EAAA;YACA,MAAA,OAAA,GAAA,IAAA,CAAA,QAAA,CAAA,EAAA,IAAA,IAAA,CAAA,IAAA;YACA;YACA,IAAA,CAAA,gBAAA,CAAA,IAAA,CAAA,QAAA,CAAA,EAAA,IAAA,OAAA,EAAA,IAAA,CAAA;UACA,CAAA,MAAA;YAAA,IAAA,CAAA,QAAA,CAAA,KAAA,CAAA,IAAA,CAAA,GAAA,CAAA;UAAA;QACA,CAAA,CAAA;MACA,CAAA,CAAA;IACA,CAAA;IACA,gBAAA,CAAA,cAAA,EAAA,QAAA,EAAA;MACA;MACA,MAAA,MAAA,GAAA,IAAA,CAAA,KAAA,CAAA,aAAA,GAAA,IAAA,CAAA,KAAA,CAAA,aAAA,CAAA,SAAA,CAAA,CAAA,GAAA,IAAA,CAAA,YAAA;MACA,IAAA,CAAA,cAAA,EAAA;QACA;QACA,IAAA,CAAA,QAAA,CAAA,OAAA,CAAA,MAAA,CAAA;QACA,IAAA,CAAA,WAAA,CAAA,CAAA;QACA,IAAA,CAAA,MAAA,CAAA,WAAA,CAAA,CAAA;QACA;MACA;MACA,IAAA,CAAA,KAAA,CAAA;QACA,GAAA,EAAA,yCAAA,cAAA,EAAA;QACA,MAAA,EAAA,MAAA;QACA,IAAA,EAAA;MACA,CAAA,CAAA,CAAA,IAAA,CAAA,CAAA;QAAA;MAAA,CAAA,KAAA;QACA,IAAA,CAAA,QAAA,CAAA,OAAA,CAAA,MAAA,CAAA;QACA,IAAA,CAAA,WAAA,CAAA,CAAA;QACA,IAAA,CAAA,MAAA,CAAA,WAAA,CAAA,CAAA;MACA,CAAA,CAAA,CAAA,KAAA,CAAA,MAAA;QACA;QACA,IAAA,CAAA,QAAA,CAAA,OAAA,CAAA,yBAAA,CAAA;QACA,IAAA,CAAA,WAAA,CAAA,CAAA;QACA,IAAA,CAAA,MAAA,CAAA,WAAA,CAAA,CAAA;MACA,CAAA,CAAA;IACA,CAAA;IACA,WAAA,CAAA,EAAA;MACA,IAAA,CAAA,MAAA,CAAA,QAAA,GAAA,IAAA;MACA,IAAA,CAAA,MAAA,CAAA,eAAA,GAAA,KAAA;IACA;EACA;AACA,CAAA","sourcesContent":["<template>\n  <div class=\"addEdit-block\">\n    <el-card>\n      <div slot=\"header\">\n        <span>{{ type === 'info' ? '竞赛详情' : (ruleForm.id ? '编辑竞赛' : '发布竞赛') }}</span>\n        <el-button style=\"float:right\" type=\"text\" @click=\"singleClose()\">返回列表</el-button>\n      </div>\n\n      <el-form class=\"detail-form-content\" ref=\"ruleForm\" :model=\"ruleForm\" :rules=\"rules\" label-width=\"120px\" :disabled=\"type === 'info'\">\n        <el-divider content-position=\"left\">基本信息</el-divider>\n        <el-row :gutter=\"20\">\n          <el-col :span=\"12\">\n            <el-form-item label=\"竞赛名称\" prop=\"jingsaimingcheng\">\n              <el-input v-model=\"ruleForm.jingsaimingcheng\" placeholder=\"竞赛名称\" clearable></el-input>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"竞赛类型\" prop=\"jingsaileixing\">\n              <el-input v-model=\"ruleForm.jingsaileixing\" placeholder=\"如：数学建模、程序设计等\" clearable></el-input>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"竞赛级别\" prop=\"jingsaijib\">\n              <el-select v-model=\"ruleForm.jingsaijib\" placeholder=\"请选择竞赛级别\" style=\"width:100%\">\n                <el-option label=\"校级\" value=\"校级\"></el-option>\n                <el-option label=\"省级\" value=\"省级\"></el-option>\n                <el-option label=\"国家级\" value=\"国家级\"></el-option>\n                <el-option label=\"国际级\" value=\"国际级\"></el-option>\n              </el-select>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"竞赛地点\" prop=\"jingsaididian\">\n              <el-input v-model=\"ruleForm.jingsaididian\" placeholder=\"竞赛地点\" clearable></el-input>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"竞赛状态\" prop=\"zhuangtai\">\n              <el-select v-model=\"ruleForm.zhuangtai\" placeholder=\"请选择\" style=\"width:100%\">\n                <el-option label=\"报名中\" value=\"报名中\"></el-option>\n                <el-option label=\"进行中\" value=\"进行中\"></el-option>\n                <el-option label=\"已结束\" value=\"已结束\"></el-option>\n              </el-select>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"模式\" prop=\"moshi\">\n              <el-select v-model=\"ruleForm.moshi\" placeholder=\"收费模式\" style=\"width:100%\">\n                <el-option v-for=\"(item,index) in moshiOptions\" :key=\"index\" :label=\"item\" :value=\"item\"></el-option>\n              </el-select>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"收费标准\">\n              <el-input v-model=\"ruleForm.shoufeibiaozhun\" placeholder=\"如：免费 或 100元/队\" clearable></el-input>\n            </el-form-item>\n          </el-col>\n        </el-row>\n\n        <el-divider content-position=\"left\">时间设置</el-divider>\n        <el-row :gutter=\"20\">\n          <el-col :span=\"12\">\n            <el-form-item label=\"报名开始时间\">\n              <el-date-picker v-model=\"ruleForm.baomingkaishi\" type=\"datetime\" value-format=\"yyyy-MM-dd HH:mm:ss\" placeholder=\"报名开始时间\" style=\"width:100%\"></el-date-picker>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"报名截止时间\">\n              <el-date-picker v-model=\"ruleForm.baomingjiezhi\" type=\"datetime\" value-format=\"yyyy-MM-dd HH:mm:ss\" placeholder=\"报名截止时间\" style=\"width:100%\"></el-date-picker>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"竞赛时间\">\n              <el-date-picker v-model=\"ruleForm.jingsaishijian\" type=\"datetime\" value-format=\"yyyy-MM-dd HH:mm:ss\" placeholder=\"竞赛时间\" style=\"width:100%\"></el-date-picker>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"提交截止时间\">\n              <el-date-picker v-model=\"ruleForm.tijiaojiezhi\" type=\"datetime\" value-format=\"yyyy-MM-dd HH:mm:ss\" placeholder=\"作品提交截止时间\" style=\"width:100%\"></el-date-picker>\n            </el-form-item>\n          </el-col>\n        </el-row>\n\n        <el-divider content-position=\"left\">竞赛内容</el-divider>\n        <el-row :gutter=\"20\">\n          <el-col :span=\"24\">\n            <el-form-item label=\"参赛要求\">\n              <el-input v-model=\"ruleForm.cansaiyaoqiu\" type=\"textarea\" :rows=\"3\" placeholder=\"参赛资格要求、人员限制等\"></el-input>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"24\">\n            <el-form-item label=\"竞赛规则\">\n              <el-input v-model=\"ruleForm.jingsaiguize\" type=\"textarea\" :rows=\"4\" placeholder=\"竞赛规则、评分标准等详细说明\"></el-input>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"24\">\n            <el-form-item label=\"奖项设置\">\n              <el-input v-model=\"ruleForm.jiangxiangshezhi\" type=\"textarea\" :rows=\"3\" placeholder=\"如：一等奖1名，奖金5000元；二等奖3名，奖金3000元...\"></el-input>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"24\">\n            <el-form-item label=\"竞赛奖励\">\n              <el-input v-model=\"ruleForm.jingsaijiangli\" type=\"textarea\" :rows=\"3\" placeholder=\"奖励说明（奖金、荣誉证书等）\"></el-input>\n            </el-form-item>\n          </el-col>\n        </el-row>\n\n        <el-divider content-position=\"left\">封面与发布者</el-divider>\n        <el-row :gutter=\"20\">\n          <el-col :span=\"12\">\n            <el-form-item label=\"工号\">\n              <el-input v-model=\"ruleForm.gonghao\" placeholder=\"教师工号\" clearable></el-input>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"教师姓名\">\n              <el-input v-model=\"ruleForm.jiaoshixingming\" placeholder=\"教师姓名\" clearable></el-input>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"24\">\n            <el-form-item label=\"封面图片\">\n              <el-upload\n                :action=\"uploadUrl\"\n                :headers=\"uploadHeaders\"\n                list-type=\"picture-card\"\n                :on-success=\"handleUploadSuccess\"\n                :on-remove=\"handleRemove\"\n                :file-list=\"fileList\"\n                :limit=\"1\"\n                :disabled=\"type === 'info'\">\n                <i class=\"el-icon-plus\"></i>\n              </el-upload>\n              <div v-if=\"ruleForm.fengmiantupian && type === 'info'\" style=\"margin-top:8px\">\n                <img :src=\"ruleForm.fengmiantupian\" style=\"width:120px;height:120px;object-fit:cover;border-radius:4px\" />\n              </div>\n            </el-form-item>\n          </el-col>\n        </el-row>\n\n        <!-- ===== 动态报名字段配置 ===== -->\n        <el-divider content-position=\"left\">\n          <i class=\"el-icon-setting\" style=\"margin-right:4px\"></i>\n          报名信息配置\n        </el-divider>\n        <el-row v-if=\"type !== 'info'\">\n          <el-col :span=\"24\">\n            <el-form-item label-width=\"0\">\n              <field-designer ref=\"fieldDesigner\" v-model=\"customFields\"></field-designer>\n            </el-form-item>\n          </el-col>\n        </el-row>\n        <el-row v-else>\n          <el-col :span=\"24\">\n            <div v-if=\"customFields.length === 0\" style=\"color:#909399;font-size:13px;padding:8px 0\">\n              该竞赛未配置自定义报名字段\n            </div>\n            <div v-else>\n              <el-tag v-for=\"f in customFields\" :key=\"f.fieldKey\" style=\"margin:4px\">\n                {{ f.fieldLabel }}（{{ typeNameMap[f.fieldType] || f.fieldType }}）\n                <span v-if=\"f.required === '是'\" style=\"color:#f56c6c\">*</span>\n              </el-tag>\n            </div>\n          </el-col>\n        </el-row>\n\n        <el-form-item v-if=\"type !== 'info'\" style=\"text-align:center;margin-top:24px\">\n          <el-button type=\"primary\" icon=\"el-icon-check\" @click=\"submitForm('ruleForm')\">保存发布</el-button>\n          <el-button icon=\"el-icon-close\" @click=\"singleClose()\">取消</el-button>\n        </el-form-item>\n      </el-form>\n    </el-card>\n  </div>\n</template>\n\n<script>\nimport FieldDesigner from './FieldDesigner'\nexport default {\n  components: { FieldDesigner },\n  props: ['parent'],\n  data() {\n    return {\n      type: 'else',\n      ro: {},\n      ruleForm: { zhuangtai: '报名中', moshi: '免费', jingsaijib: '国家级' },\n      rules: {\n        jingsaimingcheng: [{ required: true, message: '请输入竞赛名称', trigger: 'blur' }],\n        jingsaijib: [{ required: true, message: '请选择竞赛级别', trigger: 'change' }]\n      },\n      moshiOptions: ['付费', '免费'],\n      fileList: [],\n      customFields: [],  // 动态字段列表\n      typeNameMap: {\n        text: '文本', number: '数字', textarea: '多行文本',\n        radio: '单选', checkbox: '多选', select: '下拉', date: '日期'\n      }\n    }\n  },\n  computed: {\n    uploadUrl() { return `/springbootrd362/file/upload` },\n    uploadHeaders() { return { Token: this.$storage.get('Token') } }\n  },\n  methods: {\n    init(id, type) {\n      this.type = type || 'else'\n      this.ruleForm = { zhuangtai: '报名中', moshi: '免费', jingsaijib: '国家级' }\n      this.fileList = []\n      this.customFields = []\n      if (id) {\n        this.$http({ url: `jingsaixinxi/info/${id}`, method: 'get' }).then(({ data }) => {\n          if (data && data.code === 0) {\n            this.ruleForm = data.data\n            if (this.ruleForm.fengmiantupian) {\n              this.fileList = [{ name: '封面', url: this.ruleForm.fengmiantupian }]\n            }\n            // 加载该竞赛的动态字段配置\n            this.loadCustomFields(id)\n          }\n        })\n      }\n    },\n    loadCustomFields(jingsaixinxiid) {\n      this.$http({ url: `jingsaiField/list/${jingsaixinxiid}`, method: 'get' }).then(({ data }) => {\n        if (data && data.code === 0) {\n          this.customFields = data.data || []\n        }\n      })\n    },\n    handleUploadSuccess(res) {\n      if (res.code === 0) this.ruleForm.fengmiantupian = res.data\n    },\n    handleRemove() { this.ruleForm.fengmiantupian = '' },\n    submitForm(formName) {\n      this.$refs[formName].validate(valid => {\n        if (!valid) return\n        const url = this.ruleForm.id ? 'jingsaixinxi/update' : 'jingsaixinxi/save'\n        this.$http({ url, method: 'post', data: this.ruleForm }).then(({ data }) => {\n          if (data && data.code === 0) {\n            const savedId = this.ruleForm.id || data.data\n            // 保存动态字段\n            this.saveCustomFields(this.ruleForm.id || savedId, data)\n          } else { this.$message.error(data.msg) }\n        })\n      })\n    },\n    saveCustomFields(jingsaixinxiid, prevData) {\n      // 从 FieldDesigner 获取字段列表\n      const fields = this.$refs.fieldDesigner ? this.$refs.fieldDesigner.getFields() : this.customFields\n      if (!jingsaixinxiid) {\n        // 没有ID（新建后后端未返回ID），直接提示成功\n        this.$message.success('保存成功')\n        this.singleClose()\n        this.parent.getDataList()\n        return\n      }\n      this.$http({\n        url: `jingsaiField/batchSave?jingsaixinxiid=${jingsaixinxiid}`,\n        method: 'post',\n        data: fields\n      }).then(({ data }) => {\n        this.$message.success('保存成功')\n        this.singleClose()\n        this.parent.getDataList()\n      }).catch(() => {\n        // 字段保存失败不影响竞赛信息\n        this.$message.success('竞赛信息已保存（字段配置保存失败，请重新编辑）')\n        this.singleClose()\n        this.parent.getDataList()\n      })\n    },\n    singleClose() {\n      this.parent.showFlag = true\n      this.parent.addOrUpdateFlag = false\n    }\n  }\n}\n</script>\n\n<style scoped>\n.addEdit-block { padding: 16px; }\n</style>\n"],"sourceRoot":"src/views/modules/jingsaixinxi"}]}